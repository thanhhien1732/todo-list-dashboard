generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  NEW
  TODO
  IN_PROGRESS
  IN_REVIEW
  ON_HOLD
  COMPLETED
  CLOSED
  CANCELLED
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(NEW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isDeleted   Boolean    @default(false) // false = 0 (chưa xóa), true = 1 (đã xóa)
  deletedAt   DateTime?  // Lưu lại thời điểm bị xóa (nếu có)

  @@map("tasks")
}